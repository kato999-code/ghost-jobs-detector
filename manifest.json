{
  "manifest_version": 3,
  "name": "Ghost Jobs Detector",
  "version": "0.2.0",
  "description": "Universal visual sandbox extension that detects ghost job listings across LinkedIn, Indeed, ZipRecruiter, Glassdoor, JobStreet, and MyCareersFuture using a signature scoring formula (Text DNA, Cross-Platform Sync, Salary Transparency).",
  "author": "Casey",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Ghost Jobs Detector",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [],
  "host_permissions": [
    "https://*.linkedin.com/jobs/*",
    "https://*.indeed.com/*",
    "https://*.ziprecruiter.com/jobs*",
    "https://*.glassdoor.com/*",
    "https://*.jobstreet.com.sg/*",
    "https://*.mycareersfuture.gov.sg/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/jobs/*",
        "https://*.indeed.com/*",
        "https://*.ziprecruiter.com/jobs*",
        "https://*.glassdoor.com/*",
        "https://*.jobstreet.com.sg/*",
        "https://*.mycareersfuture.gov.sg/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png", "styles.css"],
      "matches": [
        "https://*.linkedin.com/*",
        "https://*.indeed.com/*",
        "https://*.ziprecruiter.com/*",
        "https://*.glassdoor.com/*",
        "https://*.jobstreet.com.sg/*",
        "https://*.mycareersfuture.gov.sg/*"
      ]
    }
  ]
}